{
  "manifest_version": 3,
  "name": "LeetLog AI",
  "version": "1.0",
  "description": "Auto-generate Medium blogs from LeetCode using Gemini",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:10000/*",
    "https://*.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}